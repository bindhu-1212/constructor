#include <bits/stdc++.h>
using namespace std;
class Myclass
{
    private:
    int a,b;
    public:
    friend void show (Myclass &c ,int n1,int n2);
};
void show (Myclass &c,int n1,int n2)
{
    c.a = n1;
    c.b = n2;
    cout<<"Addtion = "<<c.a+c.b;
}
int main() 
{
    Myclass c;
	show(c,5,8);
}
